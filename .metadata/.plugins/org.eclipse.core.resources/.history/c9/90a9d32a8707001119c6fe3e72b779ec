package ie.atu.sw;

public class Runner {

	public static void main(String[] args) {
		
		int numbers[] = [1,10,50,100,250,2000,3651,5412,1,2,5,258,28];
		
		//System.out.println(findLargestElement());
		
	}
	
	
	private int findLargestElement(int[] numbers) {
		int runningMax = 0;
		
		for (int i = 0; i < numbers.length; i++ ) {
			if (numbers[i] > runningMax ) {
				runningMax = numbers[i];
			}
		}
		
		return runningMax;
		
	}
	
}
